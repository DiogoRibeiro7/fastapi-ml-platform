APP_NAME=FastAPI ML Platform
APP_ENV=development
LOG_LEVEL=INFO
API_KEY=dev-api-key
JWT_SECRET=dev-jwt-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin-password
DATABASE_URL=sqlite+aiosqlite:///./fraud_api.db
MODEL_ARTIFACT_PATH=artifacts/fraud_model.joblib
MODEL_METADATA_PATH=artifacts/fraud_model_metadata.json
TRAIN_BASELINE_IF_MISSING=true
ENABLE_SHAP_EXPLANATIONS=false
ENABLE_TRACING=false
OTEL_SERVICE_NAME=fastapi-ml-platform
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
MIN_REVIEW_SCORE=0.65
MIN_DECLINE_SCORE=0.90
PROCESS_JOBS_INLINE=false
# SCHEDULED_REPORT_INTERVAL_SECONDS=3600
MAX_INGEST_RECORDS=10000
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
