APP_NAME=FastAPI ML Platform
APP_ENV=development
LOG_LEVEL=INFO
API_KEY=dev-api-key
DATABASE_URL=sqlite+aiosqlite:///./fraud_api.db
MODEL_ARTIFACT_PATH=artifacts/fraud_model.joblib
MODEL_METADATA_PATH=artifacts/fraud_model_metadata.json
TRAIN_BASELINE_IF_MISSING=true
ENABLE_SHAP_EXPLANATIONS=false
ENABLE_TRACING=false
OTEL_SERVICE_NAME=fastapi-ml-platform
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
MIN_REVIEW_SCORE=0.65
MIN_DECLINE_SCORE=0.90
