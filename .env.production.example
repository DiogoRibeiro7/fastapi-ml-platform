# Production profile. Copy to .env (or inject as environment variables / secrets)
# for a production deployment. Startup FAILS if APP_ENV=production and any of
# API_KEY, JWT_SECRET, or BOOTSTRAP_ADMIN_PASSWORD is left at its dev default.
APP_ENV=production
LOG_LEVEL=INFO

# Required: strong, unique secrets (source from a secrets manager).
API_KEY=replace-with-strong-api-key
JWT_SECRET=replace-with-strong-jwt-secret-32-bytes-or-more
ACCESS_TOKEN_EXPIRE_MINUTES=30
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password

# Managed Postgres (async driver required).
DATABASE_URL=postgresql+asyncpg://user:password@prod-db:5432/fraud
# Manage the schema with Alembic in production; disable startup create_all.
AUTO_CREATE_TABLES=false

# Observability and governance.
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
SCHEDULED_REPORT_INTERVAL_SECONDS=3600
DATA_RETENTION_DAYS=90
RETENTION_CLEANUP_INTERVAL_SECONDS=86400
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=1048576
