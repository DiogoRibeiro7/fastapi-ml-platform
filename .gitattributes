# Normalize all text files to LF in the repository and working tree.
* text=auto eol=lf

# Windows scripts need CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary artifacts — never touch line endings.
*.joblib binary
*.pkl binary
*.onnx binary
*.png binary
*.jpg binary
*.ico binary
