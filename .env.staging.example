# Staging profile. Copy to .env (or inject as environment variables) for a
# staging deployment. Override every secret with a staging-specific value.
APP_ENV=staging
LOG_LEVEL=INFO

# Use real, staging-only secrets (do not reuse production secrets).
API_KEY=replace-with-staging-api-key
JWT_SECRET=replace-with-staging-jwt-secret
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-staging-admin-password

# Managed Postgres (async driver required).
DATABASE_URL=postgresql+asyncpg://user:password@staging-db:5432/fraud

# Observability and governance.
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
SCHEDULED_REPORT_INTERVAL_SECONDS=3600
DATA_RETENTION_DAYS=30
RETENTION_CLEANUP_INTERVAL_SECONDS=86400
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=1048576
